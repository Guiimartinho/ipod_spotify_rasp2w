# Copy to .env (gitignored) and fill in. Spotipy reads the SPOTIPY_* variables
# automatically. Create an app at https://developer.spotify.com/dashboard to get
# the client id/secret and to register the redirect URI.
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1

# Optional Redis overrides (defaults shown). Used by config.py / datastore.py.
# SPOT_REDIS_HOST=127.0.0.1
# SPOT_REDIS_PORT=6379
# SPOT_REDIS_DB=0
# SPOT_REDIS_PASSWORD=

# Optional: logging level (DEBUG/INFO/WARNING) and X display for screen blanking.
# SPOT_LOG_LEVEL=INFO
# DISPLAY=:0
